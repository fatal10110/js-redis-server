{
  "name": "js-redis-server",
  "version": "0.0.2",
  "description": "In-memory Redis-compatible server implementation in JavaScript, useful for testing and client-agnostic mocks",
  "keywords": [
    "redis",
    "resp",
    "server",
    "mock",
    "testing",
    "ioredis",
    "node-redis",
    "in-memory",
    "cluster"
  ],
  "license": "MIT",
  "author": "fatal10110",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fatal10110/js-redis-server.git"
  },
  "bugs": {
    "url": "https://github.com/fatal10110/js-redis-server/issues"
  },
  "homepage": "https://github.com/fatal10110/js-redis-server#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "js-redis-server": "dist/cli.js"
  },
  "sideEffects": false,
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rm -rf ./dist && tsc && node -e \"const f=require('fs');const p='dist/cli.js';f.writeFileSync(p,'#!/usr/bin/env node\\n'+f.readFileSync(p,'utf8'));f.chmodSync(p,0o755)\"",
    "start": "npm run build && node --enable-source-maps ./dist/cli.js",
    "test": "tsc --noEmit && glob -c \"node --enable-source-maps --import tsx --no-warnings --test\" \"./tests/**/*.test.ts\"",
    "test:integration:mock": "tsc --noEmit && TEST_BACKEND=mock glob -c \"node --enable-source-maps --import tsx --no-warnings --test\" \"./tests-integration/**/*.test.ts\"",
    "test:integration:real": "tsc --noEmit && npm run clean:redis && TEST_BACKEND=real glob -c \"node --enable-source-maps --import tsx --no-warnings --test-concurrency 1 --test-timeout 30000 --test\" \"./tests-integration/**/*.test.ts\"",
    "test:all": "npm run test && npm run test:integration:mock && npm run test:integration:real",
    "clean:redis": "redis-cli --cluster call 127.0.0.1:30000 FLUSHALL || redis-cli FLUSHALL || echo 'Redis cleanup attempted'",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.+(js|ts|json)\"",
    "prepublishOnly": "npm run build && npm test",
    "prepare": "husky"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "cluster-key-slot": "^1.1.2",
    "ioredis-mock": "^8.9.0",
    "lua-redis-wasm": "^1.2.2",
    "respjs": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.9.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.4",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "glob": "^11.0.0",
    "globals": "^14.0.0",
    "husky": "^9.1.5",
    "ioredis": "^5.4.1",
    "lint-staged": "^15.2.10",
    "prettier": "3.3.3",
    "redis": "^5.1.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
